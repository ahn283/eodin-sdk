{
  "name": "@eodin/capacitor",
  "version": "2.0.0-beta.1",
  "description": "Eodin SDK for Capacitor - Deferred Deep Link & Analytics",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahn283/eodin-sdk.git",
    "directory": "packages/capacitor"
  },
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/",
    "ios/",
    "dist/",
    "*.podspec",
    "Package.swift"
  ],
  "keywords": [
    "capacitor",
    "plugin",
    "deeplink",
    "analytics",
    "eodin"
  ],
  "scripts": {
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf dist",
    "docgen": "echo 'docgen skipped'",
    "docs": "typedoc --options typedoc.json",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "npm run build",
    "lint": "echo 'lint skipped'"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "dependencies": {
    "@eodin/web": "^1.0.0-beta.1"
  },
  "peerDependencies": {
    "@capacitor/core": ">=5.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.26.11",
    "typescript": "~5.3.0"
  }
}
