{
  "name": "eodin-web",
  "version": "1.0.0-beta.1",
  "description": "Eodin SDK for Web - Pure analytics SDK (5번째 채널). 4채널 (Flutter / iOS / Android / Capacitor) 와 의미 parity.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahn283/eodin-sdk.git",
    "directory": "packages/sdk-web"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./internal": {
      "types": "./dist/esm/internal/index.d.ts",
      "import": "./dist/esm/internal/index.js",
      "require": "./dist/cjs/internal/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "eodin",
    "analytics",
    "web",
    "logging",
    "sdk"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf dist",
    "docs": "typedoc --options typedoc.json",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.26.11",
    "typescript": "~5.3.0"
  }
}
